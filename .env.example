# Copy this file to .env and fill in the values. .env is gitignored.

# Micromart session cookie (manually supplied for the MVP — no login/2FA)
MICROMART_COOKIE=

# Base URL of the Micromart API
MICROMART_BASE_URL=

# Default site (vending machine) whose planogram the session loads
DEFAULT_SITE_ID=

# Default Micromart restock session id that correction events post to
DEFAULT_RESTOCK_SESSION_ID=

# Port the backend listens on
PORT=
